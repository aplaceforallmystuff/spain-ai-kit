{
  "name": "spain-ai-kit",
  "version": "0.1.1",
  "license": "MIT",
  "private": true,
  "description": "Spanish Government APIs MCP Servers - Monorepo",
  "author": {
    "name": "Jim Christian",
    "url": "https://jimchristian.net"
  },
  "workspaces": [
    "packages/*",
    "mcp/*"
  ],
  "scripts": {
    "build": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "format": "prettier --write .",
    "clean": "nx run-many --target=clean --all && rm -rf node_modules",
    "dev": "nx run-many --target=dev --all --parallel",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nx": "^21.6.11",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^5.9.0",
    "vitest": "^2.0.0"
  },
  "lint-staged": {
    "**/*.ts": [
      "prettier --check"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.16.1",
    "fast-xml-parser": "^5.8.0"
  }
}
